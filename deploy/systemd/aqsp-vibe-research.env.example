# Copy to /etc/aqsp/vibe-research.env on the server and adjust paths only.
# Do not put API keys, webhook secrets, or .env contents in this file.
AQSP_RESEARCH_SURFACE_SNAPSHOT=/opt/aqsp/data/runtime/home_dashboard_snapshot.json
PYTHONPATH=/opt/aqsp/src:/opt/aqsp/backend
VIBE_RESEARCH_FRONTEND_HOST=127.0.0.1
VIBE_RESEARCH_FRONTEND_PORT=5899
VIBE_RESEARCH_BACKEND_HOST=127.0.0.1
VIBE_RESEARCH_BACKEND_PORT=8900
VR_DATA_DIR=/opt/aqsp/data/vibe-research
VR_PUBLIC_MODE=0
VR_ALLOW_ORIGINS=http://127.0.0.1:5899
