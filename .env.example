# A 股代码，逗号分隔。留空时本地优先从 TDX 全市场按成交额预筛。
AQSP_SYMBOLS=

# open: 开盘前/盘中观察池；close: 尾盘/收盘后候选池。
AQSP_MODE=close
AQSP_LIMIT=10
AQSP_MAX_UNIVERSE=100
AQSP_MIN_AVG_AMOUNT=50000000
AQSP_ENABLE_ONLINE_FACTORS=false
AQSP_ALLOW_ONLINE_FALLBACK=true
AQSP_MAX_DATA_LAG_DAYS=3
AQSP_SOURCE=auto
AQSP_LEDGER=data/predictions.jsonl
AQSP_PAPER_LEDGER=data/paper_trades.jsonl
AQSP_REPORT=reports/latest.md
AQSP_OUTPUT_CSV=reports/latest.csv
AQSP_PAPER_REPORT=reports/paper.md
AQSP_DASHBOARD=dist/dashboard/index.html
AQSP_DASHBOARD_HTML=dist/dashboard/index.html
AQSP_DASHBOARD_DB=dist/dashboard/aqsp.db

# 私有本地/服务器 SQLite 数据库路径。不要上传数据库文件本体。
AQSP_SQLITE_DB_PATH=A股量化分析数据/astocks_qfq.db

# 通知渠道，配置任意一个即可。
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SERVERCHAN_SENDKEY=
WECHAT_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=

# 私有服务器前端/SQLite 部署。真实值只放 GitHub Actions Secrets。
AQSP_DEPLOY_DASHBOARD=false
AQSP_DEPLOY_HOST=
AQSP_DEPLOY_PORT=22
AQSP_DEPLOY_USER=
AQSP_DEPLOY_PATH=
AQSP_DEPLOY_SSH_KEY=

# 多 Agent 讨论运行时配置。默认中文角色，默认不开启。
AQSP_NOTIFY=false
AQSP_ENABLE_DEBATE=false
AQSP_DEBATE_ENABLE_LLM=false
AQSP_DEBATE_MAX_ROUNDS=2
AQSP_DEBATE_LANGUAGE=zh-CN
AQSP_DEBATE_ROLES=bull,bear,risk_control,sector_leader,policy_sensitive,northbound
AQSP_ENABLE_AUTO_EVOLUTION=false

# 研究采集/数据源 token。只放本地 .env 或 GitHub Actions Secrets，禁止提交真实值。
GITHUB_TOKEN=
GITEE_TOKEN=
TUSHARE_TOKEN=

# ====================================
# LLM 配置 - 支持多种免费/低价模型
# ====================================

# 开启 LLM 增强简报
ENABLE_LLM_BRIEFING=1

# 选择 LLM provider（默认 glm，永久免费不限量）
# 支持: glm, qwen, siliconflow, deepseek, openai, anthropic, custom
LLM_PROVIDER=glm

# ================== 推荐方案（按性价比排序）==================

# --- 方案1: 智谱GLM-4.7-Flash（推荐首选）---
# 注册: https://open.bigmodel.cn/
# 模型: GLM-4.7-Flash
# 效果: 中文理解优秀，适合A股分析场景
GLM_API_KEY=

# --- 方案2: 通义千问 qwen-turbo（新用户500万tokens，免费180天）---
# 注册: https://dashscope.console.aliyun.com/
# 额度: qwen-turbo 200万tokens / qwen-plus 100万tokens（180天）
# 效果: 阿里大模型，中文能力强
QWEN_API_KEY=
# 可选模型: qwen-turbo(快便宜), qwen-plus(均衡), qwen-max(最强)

# --- 方案3: 硅基流动（注册送14元，部分模型永久免费）---
# 注册: https://cloud.siliconflow.cn/
# 额度: 注册送14元，邀请好友再得14元；部分7B小模型永久免费
# 效果: 聚合平台，可调用Qwen/GLM/Llama等多种模型
SILICONFLOW_API_KEY=
# 默认启用免费白名单护栏，拒绝 Pro/ 收费模型
SILICONFLOW_FREE_ONLY=true
# 可选免费模型: Qwen/Qwen2.5-7B-Instruct, THUDM/glm-4-9b-chat, internlm/internlm2_5-7b-chat
# SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- 方案4: DeepSeek（不免费，2元/百万tokens，效果最强）---
# 注册: https://platform.deepseek.com/
# 额度: 无免费额度，需充值（输入2元/百万tokens，输出8元/百万tokens）
# 效果: 国产最强推理模型，复杂分析场景首选
DEEPSEEK_API_KEY=

# ================== 其他选项 ==================
# --- OpenAI ---
OPENAI_API_KEY=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- 自定义 OpenAI 兼容端点（如本地Ollama）---
CUSTOM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1
API_KEY=dummy
