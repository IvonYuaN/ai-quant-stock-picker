# A 股代码，逗号分隔。留空时使用 sample universe。
AQSP_SYMBOLS=600519,300750,000001

# open: 开盘前/盘中观察池；close: 尾盘/收盘后候选池。
AQSP_MODE=close
AQSP_LIMIT=10
AQSP_MIN_AVG_AMOUNT=50000000
AQSP_MAX_DATA_LAG_DAYS=3

# 通知渠道，配置任意一个即可。
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WECHAT_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=
