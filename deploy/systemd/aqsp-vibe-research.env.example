# Copy to /etc/aqsp/vibe-research.env on the server and adjust paths only.
# Do not put API keys, webhook secrets, or .env contents in this file.
AQSP_RESEARCH_SURFACE_SNAPSHOT=/opt/aqsp/data/runtime/home_dashboard_snapshot.json
AQSP_LEDGER=/opt/aqsp/data/predictions.jsonl
AQSP_PAPER_LEDGER=/opt/aqsp/data/paper_trades.jsonl
AQSP_DEBATE_RESULTS=/opt/aqsp/data/debate_results.jsonl
AQSP_INTRADAY_LEDGER=/opt/aqsp/data/intraday_predictions.jsonl
AQSP_INTRADAY_LATEST_CSV=/opt/aqsp/reports/intraday_latest.csv
AQSP_NEWS_JSON_OUTPUT=/opt/aqsp/data/runtime/news_catalysts_latest.json
AQSP_NEWS_ARCHIVE_DIR=/opt/aqsp/data/runtime/news_archive
PYTHONPATH=/opt/aqsp/src:/opt/aqsp/backend
VIBE_RESEARCH_FRONTEND_HOST=127.0.0.1
VIBE_RESEARCH_FRONTEND_PORT=5899
VIBE_RESEARCH_BACKEND_HOST=127.0.0.1
VIBE_RESEARCH_BACKEND_PORT=8900
AQSP_ALLOW_STALE_SNAPSHOT=1
AQSP_DISABLE_CIRCUIT_BREAKER=true
AQSP_INTRADAY_DISABLE_CIRCUIT_BREAKER=true
AQSP_RESEARCH_DISPLAY_OVERRIDE=true
VR_DATA_DIR=/opt/aqsp/data/vibe-research
VR_PUBLIC_MODE=0
VR_ALLOW_ORIGINS=http://127.0.0.1:5899
