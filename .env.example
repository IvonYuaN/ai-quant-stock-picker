# A 股代码，逗号分隔。留空时本地优先从 TDX 全市场按成交额预筛。
AQSP_SYMBOLS=

# open: 开盘前/盘中观察池；close: 尾盘/收盘后候选池。
AQSP_MODE=close
AQSP_LIMIT=10
AQSP_MAX_UNIVERSE=100
AQSP_MIN_AVG_AMOUNT=50000000
AQSP_ENABLE_ONLINE_FACTORS=false
AQSP_MAX_DATA_LAG_DAYS=3
AQSP_SOURCE=auto
AQSP_LEDGER=data/predictions.jsonl
AQSP_PAPER_LEDGER=data/paper_trades.jsonl
AQSP_REPORT=reports/latest.md
AQSP_OUTPUT_CSV=reports/latest.csv
AQSP_PAPER_REPORT=reports/paper.md
AQSP_DASHBOARD=dist/dashboard/index.html

# 私有本地/服务器 SQLite 数据库路径。不要上传数据库文件本体。
AQSP_SQLITE_DB_PATH=A股量化分析数据/astocks_qfq.db

# 通知渠道，配置任意一个即可。
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WECHAT_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=

# 私有服务器前端/SQLite 部署。真实值只放 GitHub Actions Secrets。
AQSP_DEPLOY_DASHBOARD=false
AQSP_DEPLOY_HOST=
AQSP_DEPLOY_PORT=22
AQSP_DEPLOY_USER=
AQSP_DEPLOY_PATH=
AQSP_DEPLOY_SSH_KEY=

# 研究采集/数据源 token。只放本地 .env 或 GitHub Actions Secrets，禁止提交真实值。
GITHUB_TOKEN=
GITEE_TOKEN=
TUSHARE_TOKEN=
